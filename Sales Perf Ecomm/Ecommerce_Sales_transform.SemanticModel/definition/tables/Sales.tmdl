table Sales
	lineageTag: 72facccf-8272-418a-b0a1-cd5b67a61b1a

	measure 'Total Sales' = SUM(Sales[Sales Amount])
		formatString: 0
		lineageTag: ce9ef9dd-10db-49dd-bc9c-5e4b51e889c8

	measure 'Total Quantity Sold' = SUM(Sales[Quantity])
		formatString: 0
		lineageTag: 8f2a1f3b-5bb5-4435-b703-f014d10950e2

	measure 'Total Orders' = DISTINCTCOUNT(Sales[Order ID])
		formatString: 0
		lineageTag: 52daaca6-bcf7-49e8-9ec9-a5e52e12093c

	measure 'Total Customers' = DISTINCTCOUNT(Customers[Customer ID])
		formatString: 0
		lineageTag: b1d610a3-c07e-4f3e-a8cf-51c1645307f8

	measure AOV = DIVIDE([Total Sales],[Total Orders],0)
		lineageTag: 17ac7cd3-5530-4b54-9c6b-7c7c1854b074

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AIPO = DIVIDE([Total Quantity Sold],[Total Orders],0)
		lineageTag: 9332c644-8336-4d37-9355-58da990170b6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ARPC = DIVIDE([Total Sales],[Total Customers],0)
		lineageTag: 645c4d0a-7374-409f-a0ee-274fe04e7f2d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Sales All' = CALCULATE(SUM(Sales[Sales Amount]),ALL(Sales))
		formatString: 0
		lineageTag: 356e1100-106c-40ac-b0c2-1fe775b7cbc6

	measure 'Total Quantity Sold All' = CALCULATE(SUM(Sales[Quantity]),ALL(Sales))
		formatString: 0
		lineageTag: 3cce8455-616d-4710-ae3f-88ca7c69a07c

	measure 'Total Orders All' = CALCULATE(DISTINCTCOUNT(Sales[Order ID]),ALL(Sales))
		formatString: 0
		lineageTag: 31bf744d-8cda-40ab-a559-906bdf27f3ce

	measure 'AOV All' = DIVIDE([Total Sales All],[Total Orders All],0)
		lineageTag: 2cadd600-8516-48c2-b5ac-7b1c17b9ec1a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'AIPO All' = DIVIDE([Total Quantity Sold All],[Total Orders All],0)
		lineageTag: d754c4fa-db64-4f28-ac6d-68e6f1c3c5f4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Customers All' =
			CALCULATE(
			    DISTINCTCOUNT(Customers[Customer ID]),All(Sales)
			)
		formatString: 0
		lineageTag: ea038867-d9d0-451d-8718-ee11b5d7b0ef

	measure 'ARPC All' = DIVIDE([Total Sales All],[Total Customers All],0)
		lineageTag: 0a405d7b-c831-4abc-a22e-c326415cf0fd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Discount Given' = CALCULATE(SUMX(Sales, Sales[Discount] * Sales[Product Amount]), ALL(Products))
		lineageTag: 9f5ea722-2343-4cf5-8e8a-12111afa6cc0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Profit' = [Total Sales] - SUMX(Sales, Sales[Discount]* Sales[Product Amount])
		lineageTag: e003250b-b5c6-4bad-b6a4-62fd19707189

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Profit Margin' = ```
			[Total Profit] / [Total Sales] 
			```
		lineageTag: f5ab3b78-994d-40a8-99d8-064644114a86

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Discount' = AVERAGE(Sales[Discount])
		lineageTag: 2e01fd28-e2e9-4047-918a-cbde5506ccb2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Average Delivery Time' = AVERAGE(Sales[Delivery Time])
		lineageTag: e825fd7a-3acb-4df8-a8b6-131c4706dd81

		annotation PBI_FormatHint = {"isGeneralNumber":true}

